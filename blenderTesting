import pickle
import bpy
import bmesh
import math
import random





with open('listOf2dCoordsExtruded.pkl', 'rb') as f:
    loadedData = pickle.load(f)


#Naming the object
obj_name = "my shape"
#Adding mesh to the object
mesh_data = bpy.data.meshes.new(f"{obj_name}_data")
#Adding mesh object using mesh data
mesh_obj = bpy.data.objects.new(obj_name, mesh_data)
#Links the mesh to my shape and adds it to the scene
bpy.context.scene.collection.objects.link(mesh_obj)

bm = bmesh.new()
#We have our working list of tuples
vertCoords = loadedData

for coord in vertCoords:
  bm.verts.new(coord)

bm.verts.ensure_lookup_table()

###
#Working here
#Making a function that labels each point as a number in the list and return a list of tuples that have the points that will be connected to each other.
#Each tuple needs to have four points because each face (Except the top and the bottom) will be represented as a rectangle
#Once the iteration reaches the end it needs to close the object with respect to the xy plane by iterating back to the beginning with the first and last point
#For the top and the bottom need to have two separate tuples that have all the z = 1 coords and another with all of the z = 0 coords
def makeIndices(listOfCoords):
    faceVertIndices = []
    length = len(listOfCoords)
    for i in range(0, length, 2):
        #This is for the last one
        if (i+2) == length:
            faceVertTup = (i, i+1, 0, 1)
        #This is for all of the others
        else:
            faceVertTup = (i, i+1, i+2, i+3)
        faceVertIndices.append(faceVertTup)
    #This is for getting the z = 0 values for its face
    botVertList = list(range(0, length, 2))

    #This is for getting all of the z = 1 values for its face
    topVertList = list(range(1, length, 2))

    faceVertIndices.append(tuple(topVertList)) 
    faceVertIndices.append(tuple(botVertList))
    return faceVertIndices 

#Create the list of indices
indices = makeIndices(vertCoords)

#Make indices
for vertIndices in indices:
    bm.faces.new([bm.verts[index] for index in vertIndices])

#Writes bmesh data into the mesh data
bm.to_mesh(mesh_data)

#Update the mesh data, this helps with redrawing the mesh in the viewport
mesh_data.update()

#Clean up and free memory that was allocated for the bmesh
bm.free() 
